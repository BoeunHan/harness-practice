{
  "project_name": "react_app",

  "description": "Vite 기반 React + TypeScript 프로젝트를 초기화하고 dev 서버 실행이 가능한 상태까지 구성한다.",

  "goals": [
    "React + TypeScript 프로젝트 초기화",
    "Vite 기반 개발 서버 실행 가능 상태 구성",
    "기본 프로젝트 구조 생성"
  ],

  "scope": "frontend",

  "tech_stack": {
    "framework": "react",
    "language": "typescript",
    "bundler": "vite"
  },

  "libraries": ["react 19", "react-dom"],

  "architecture": ["components", "main entry (main.tsx / App.tsx)"],

  "scripts": ["dev", "build", "typecheck"],

  "constraints": [
    "src 내부에서만 코드 생성",
    "npm install 후 npm run dev로 정상 실행 가능해야 한다",
    "불필요한 라이브러리 추가 금지",
    "최소 구조로 유지한다"
  ]
}
